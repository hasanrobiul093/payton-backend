generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum AuthProvider {
  CUSTOM
  GOOGLE
  APPLE
}

enum Role {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPEND
}

model User {
  userId String @id @default(uuid())

  name     String
  email    String     @unique
  password String?
  role     Role       @default(USER)
  status   UserStatus @default(ACTIVE)

  profileImage String?

  provider   AuthProvider @default(CUSTOM)
  providerId String?

  lastOTP          String?
  otpExpiredAt     DateTime?
  refreshToken String?

  isVerified Boolean   @default(false)
  isActive   Boolean   @default(true)
  isDeleted  Boolean   @default(false)
  deletedAt  DateTime?

  lastActive DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  settings UserSettings?
}

model UserSettings {
  id String @id @default(uuid())

  userId String @unique

  enableOfflineMap   Boolean @default(false)
  enableNotification Boolean @default(true)

  hotZoneAlert  Boolean @default(true)
  groupActivity Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [userId])

  @@index([userId])
}
